//baza u fileu dev.db
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
} 
//klijent 
generator client {
  provider = "prisma-client-js"
}

//template za korisnika

model User {
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  stripeId String?  @unique
  email    String  @unique                      // svaki acc drugi mail
  password String                               // lozinka klasicni string samo
  role     String  @default("USER")             // Role: "USER" ili "ADMIN"
  firstName String? //upitnik da moze biti prazno
  lastName String?
}

// koristiti ces i namjestiti kasnije (alenovi preporuceni), nisi jos apdejtao nis 
model Customer {
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  email    String  @unique                      // svaki acc drugi mail

}
// U KORAKU (1)
model paymentIntents {
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  email    String  
  userId   Int
  role     String  @default("USER")             // Role: "USER" ili "ADMIN"
  firstName String? 
  lastName String?
  status String?
  amount       Int?      @default(0)       // Iznos u centima (Stripe standard)
  currency     String   @default("eur")   // Valuta
  items        String?                    // Opis što je kupljeno (može i Json tip)
  createdAt    DateTime @default(now())   // Da znaš kad je plaćeno
  stripeId       String? 
  capturedAmount Int?                     //za partial capture 
  refundAmount    Int?                    //za refund funkcionalnost!
}

model Webhook {
  id        Int      @id @default(autoincrement())
  type      String   
  payload   String    
  createdAt DateTime @default(now())
}

model subscriptions{
  stripePaymentId String   @unique
  plan            String          //mjesec, godina...
  userStripeId    String 
}

model invoices{
  id       Int          @id  
  amount       Int      @default(0)       
  createdAt DateTime @default(now())
  status String?
}

model refunds{
  id              Int      @id @default(autoincrement()) @unique
  stripePaymentId String   
  amount          Int      @default(0)
  email           String
  firstName String? 
  lastName String?
}

model disputes{
  stripePaymentId String   @unique
}
