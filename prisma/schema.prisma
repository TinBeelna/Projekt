//baza u fileu dev.db
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
} 
//klijent 
generator client {
  provider = "prisma-client-js"
}

//template za korisnika

model User {
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  email    String  @unique                      // svaki acc drugi mail
  password String                               // lozinka klasicni string samo
  role     String  @default("USER")             // Role: "USER" ili "ADMIN"
  firstName String? //upitnik da moze biti prazno
  lastName String?
}

// koristiti ces i namjestiti kasnije (alenovi preporuceni), nisi jos apdejtao nis 
model Customer {
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  email    String  @unique                      // svaki acc drugi mail

}

model paymentIntents {
  stripePaymentId String   @unique
}

model subscriptions{
  stripePaymentId String   @unique
}

model invoices{
  stripePaymentId String   @unique
}

model refunds{
  stripePaymentId String   @unique
}

model disputes{
  stripePaymentId String   @unique
}
