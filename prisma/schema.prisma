//baza u fileu dev.db
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
//klijent 
generator client {
  provider = "prisma-client-js"
}

//template za korisnika

model User { //ujedino i Customer
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  stripeId String?  @unique
  email    String  @unique                      // svaki acc drugi mail
  password String                               // lozinka klasicni string samo
  role     String  @default("USER")             // Role: "USER" ili "ADMIN"
  firstName String? //upitnik da moze biti prazno
  lastName String?
  invoices  Invoice[] //dodano za racune pretplata!
  cards     paymentMethod[] //dodano za kartice!
}

// koristiti ces i namjestiti kasnije (alenovi preporuceni), nisi jos apdejtao nis 
model Customer {
  id       Int     @id @default(autoincrement()) // Id je inkrementirani broj
  email    String  @unique                      // svaki acc drugi mail
}

model paymentIntents { 
  id              Int        @id @default(autoincrement()) // Id je inkrementirani broj
  email           String?  
  userId          Int?
  role            String?     @default("USER")             // Role: "USER" ili "ADMIN"
  firstName       String? 
  lastName        String?
  status          String?
  amount          Int?       @default(0)       // Iznos u centima (Stripe standard)
  currency        String     @default("eur")   // Valuta
  items           String?                    // Opis što je kupljeno (može i Json tip)
  createdAt       DateTime   @default(now())   // Da znaš kad je plaćeno
  stripeId        String?    @unique
  capturedAmount  Int?                     //za partial capture 
  refundAmount    Int?                    //za refund funkcionalnost!
  charges         charges[]
  disputes        disputes[]
  isPartial       Boolean?
  partialPayId    String?                 //za partial capture i pretragu       
}

model Webhook {
  stripeId  String?   @unique //dodano za idempotency!
  id        Int      @id @default(autoincrement())
  type      String   
  payload   String    
  createdAt DateTime @default(now())
}

model paymentMethod {
  id                String    @id @default(cuid())
  paymentMethodId   String    @unique //stripeov token koji sprema 16gid
  stripeId    String                
  LastFour    String               
  user        User            @relation(fields: [stripeId], references: [stripeId])
  CardBrand   String
  ExpMonth    Int
  ExpYear     Int
  isDefault   Boolean         @default(false)
  Fingerprint String?          //fingerprint sluzi za provjeru duplikata kartica kod korisnika
}

model subscriptions{
  stripePaymentId String  @unique
  plan            String          //mjesec, godina...
  userStripeId    String 
  status          String  @default("active")
  currency        String  @default("eur")
  invoices        Invoice[] 
  cancelAtPeriodEnd Boolean @default(false)
}

//stripe generated sub invoice
model Invoice {
  id                String      @id @default(cuid())
  stripeInvoiceId   String?      @unique 
  
  // POPRAVAK 1: userId mora biti Int jer je User.id Int
  userId            Int?
  user              User?        @relation(fields: [userId], references: [id])

  subscriptionId    String?
  subscription      subscriptions? @relation(fields: [subscriptionId], references: [stripePaymentId])
  
  invoiceNumber     String?     
  status            String?    
  total             Int?         
  currency          String?      
  
  createdAt         DateTime?    
  periodStart       DateTime?    
  periodEnd         DateTime?    
  paidAt            DateTime?   
  
  items             String?      //za spremiti vise stvari odjednom
  invoicePdfUrl     String?     
  paymentMethod     String?     
  
  @@index([userId])
  @@index([status])
}


model refunds{
  id              Int       @id @default(autoincrement()) @unique
  stripePaymentId String   
  amount          Int       @default(0)
  email           String
  firstName       String? 
  lastName        String?
  currency        String    @default("eur")
  createdAt       DateTime? @default(now())   // audit trail
}

model charges{
id                Int                @id @default(autoincrement()) @unique
stripeId          String             @unique
paymentIntent     paymentIntents?    @relation(fields: [paymentStripeId], references: [stripeId])
paymentStripeId   String?
amount            Int?               @default(0)
//disputes       disputes[]            
}

model disputes{
  id              Int      @id @default(autoincrement()) @unique
  disputeId         String             @unique  
  paymentIntent     paymentIntents?    @relation(fields: [paymentStripeId], references: [stripeId])
  chargeId          String             
 // charge            charges?           @relation(fields: [chargeId], references: [stripeId])
  paymentStripeId   String?
  reason            String?
  status            String
  evidence          String?           //ovdje je idejno
  amount            Int?               @default(0)       
}
